# Берем за основу готовый образ Linux с Python и драйверами видеокарт
FROM runpod/pytorch:2.0.1-py3.10-cuda11.8.0-devel-ubuntu22.04

# Папка внутри виртуальной машины, где будет лежать наш код
WORKDIR /app

# Устанавливаем библиотеку для работы с RunPod
RUN pip install runpod

# Копируем наш файл worker.py с твоего компьютера внутрь контейнера
COPY worker.py .

# Указываем команду, которая автоматически запустит скрипт при включении сервера
CMD [ "python", "-u", "/app/worker.py" ]